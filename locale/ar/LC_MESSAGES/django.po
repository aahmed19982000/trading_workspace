#: templates/auth/login.html:172
msgid "Sign in failed. Please try again."
msgstr "فشل تسجيل الدخول. يرجى المحاولة مرة أخرى."

#: templates/auth/login.html:181 templates/auth/register.html:206
msgid "Network error. Please try again."
msgstr "حدث خطأ في الشبكة. يرجى المحاولة مرة أخرى."

msgid "Please review the submitted data."
msgstr "يرجى مراجعة البيانات المرسلة."

msgid "Authentication credentials were not provided."
msgstr "لم يتم إرسال بيانات المصادقة."

msgid "You do not have permission to perform this action."
msgstr "ليست لديك صلاحية لتنفيذ هذا الإجراء."

msgid "The requested resource was not found."
msgstr "المورد المطلوب غير موجود."

msgid "This HTTP method is not allowed for this endpoint."
msgstr "طريقة الطلب هذه غير مسموح بها لهذا المسار."

msgid "Too many requests. Please try again in a moment."
msgstr "عدد الطلبات كبير جدًا. يرجى المحاولة بعد قليل."

msgid "The request payload could not be processed."
msgstr "تعذر معالجة بيانات الطلب."

msgid "An unexpected server error occurred."
msgstr "حدث خطأ داخلي غير متوقع في الخادم."

msgid "Please enter your email and password."
msgstr "يرجى إدخال البريد الإلكتروني وكلمة المرور."

msgid "This account is inactive."
msgstr "هذا الحساب غير مفعل."

msgid "Workspace name is required."
msgstr "اسم مساحة العمل مطلوب."

msgid "Workspace id is required."
msgstr "معرف مساحة العمل مطلوب."

